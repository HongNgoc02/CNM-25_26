<%- include('../partials/header') %>

<div class="container mt-4">
    <h2>Danh sách sản phẩm</h2>
    <a href="/create" class="btn btn-primary mb-3">Thêm sản phẩm mới</a>
    <form action="/" method="GET" class="d-flex" style="width: 400px;">
        <input type="text" name="keyword" class="form-control me-2" 
               placeholder="Nhập tên hoặc mã SP..." 
               value="<%= typeof keyword !== 'undefined' ? keyword : '' %>">
        <button class="btn btn-outline-success" type="submit">Tìm</button>
        <% if (typeof keyword !== 'undefined' && keyword !== '') { %>
            <a href="/" class="btn btn-outline-secondary ms-2">Hủy</a>
        <% } %>
    </form>
    
    <table class="table table-bordered table-hover mt-3">
    <thead class="table-dark">
        <tr>
            <th>Mã SP</th>
            <th>Ảnh</th>
            <th>Tên sản phẩm</th>
            <th>Giá</th>
            <th>Tồn kho</th>
            <th>Hành động</th>
        </tr>
    </thead>
    <tbody>
        <% if (products && products.length > 0) { %>
            <% products.forEach(product => { %>
            <tr>
                <td class="align-middle"><strong><%= product.id %></strong></td>
                
                <td class="align-middle">
                    <img src="<%= product.url_image %>" alt="Ảnh SP" width="60" class="img-thumbnail">
                </td>
                
                <td class="align-middle"><%= product.name %></td>
                
                <td class="align-middle"><%= product.price %></td>
                
                <td class="align-middle"><%= product.unit_in_stock %></td>
                
                <td class="align-middle">
                    <a href="/detail/<%= product.id %>" class="btn btn-sm btn-info text-white">Chi tiết</a>
                    <a href="/edit/<%= product.id %>" class="btn btn-sm btn-warning">Sửa</a>
                    <form action="/delete/<%= product.id %>" method="POST" style="display:inline;">
                        <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Bạn có chắc chắn muốn xóa?')">Xóa</button>
                    </form>
                </td>
            </tr>
            <% }) %>
        <% } else { %>
            <tr>
                <td colspan="6" class="text-center">Chưa có sản phẩm nào.</td>
            </tr>
        <% } %>
    </tbody>
</table>
</div>

<%- include('../partials/footer') %>